{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/api/auth/[...nextauth]",
      "regex": "^/api/auth/(.+?)(?:/)?$",
      "routeKeys": {
        "nxtPnextauth": "nxtPnextauth"
      },
      "namedRegex": "^/api/auth/(?<nxtPnextauth>.+?)(?:/)?$"
    },
    {
      "page": "/api/criteria/[id]",
      "regex": "^/api/criteria/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/criteria/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/jobs/[id]",
      "regex": "^/api/jobs/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/jobs/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/jobs/[id]/criteria",
      "regex": "^/api/jobs/([^/]+?)/criteria(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/jobs/(?<nxtPid>[^/]+?)/criteria(?:/)?$"
    },
    {
      "page": "/api/orgs/[id]",
      "regex": "^/api/orgs/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/orgs/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/orgs/[id]/members",
      "regex": "^/api/orgs/([^/]+?)/members(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/orgs/(?<nxtPid>[^/]+?)/members(?:/)?$"
    },
    {
      "page": "/api/scenarios/[id]",
      "regex": "^/api/scenarios/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/scenarios/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/sessions/[id]",
      "regex": "^/sessions/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/sessions/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/simulate/[sessionId]",
      "regex": "^/simulate/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPsessionId": "nxtPsessionId"
      },
      "namedRegex": "^/simulate/(?<nxtPsessionId>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/admin",
      "regex": "^/admin(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin(?:/)?$"
    },
    {
      "page": "/analytics",
      "regex": "^/analytics(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/analytics(?:/)?$"
    },
    {
      "page": "/auth/signin",
      "regex": "^/auth/signin(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/auth/signin(?:/)?$"
    },
    {
      "page": "/favicon.ico",
      "regex": "^/favicon\\.ico(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/favicon\\.ico(?:/)?$"
    },
    {
      "page": "/sessions",
      "regex": "^/sessions(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/sessions(?:/)?$"
    },
    {
      "page": "/simulate",
      "regex": "^/simulate(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/simulate(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}